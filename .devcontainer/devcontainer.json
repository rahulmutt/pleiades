{
  "name": "pleiades",
  "image": "ghcr.io/rahulmutt/dev:sha-d294056",
  "workspaceFolder": "/workspace",
  "remoteUser": "dev",
  "containerEnv": {
    "CARGO_HOME": "/home/dev/.cargo",
    "RUSTUP_HOME": "/home/dev/.rustup"
  },
  "mounts": [
    "source=devpod-v2-home-cache,target=/home/dev/.cache,type=volume",
    "source=devpod-v2-home-local,target=/home/dev/.local,type=volume",
    "source=devpod-v2-bun,target=/home/dev/.bun,type=volume",
    "source=devpod-v2-npm,target=/home/dev/.npm,type=volume",
    "source=devpod-v2-cargo,target=/home/dev/.cargo,type=volume",
    "source=devpod-v2-rustup,target=/home/dev/.rustup,type=volume",
  ],
  "postCreateCommand": "post-create.sh",
  "customizations": {
    "devpod": {
      "ide": "none"
    }
  }
}
